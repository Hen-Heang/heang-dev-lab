<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.heang.springmybatistest.mapper.BgtMngMapper">

    <!-- ResultMap: DB column (snake_case) → Java field (camelCase) -->
    <resultMap id="bgtMngOutResult" type="com.heang.springmybatistest.vo.BgtMngOutVO">
        <id     property="id"         column="id"/>
        <result property="rn"         column="rn"/>
        <result property="jijacheNm"  column="jijache_nm"/>
        <result property="startMm"    column="start_mm_full"/>
        <result property="endMm"      column="end_mm_full"/>
        <result property="ntnlBgt"    column="ntnl_bgt"/>
        <result property="lclBgt"     column="lcl_bgt"/>
        <result property="bgtSum"     column="bgt_sum"/>
    </resultMap>

    <resultMap id="bgtMngDetailResult" type="com.heang.springmybatistest.vo.BgtMngVO">
        <id     property="id"         column="id"/>
        <result property="sidoCd"     column="sido_cd"/>
        <result property="sidoNm"     column="sido_nm"/>
        <result property="sigunguCd"  column="sigungu_cd"/>
        <result property="sigunguNm"  column="sigungu_nm"/>
        <result property="guCd"       column="gu_cd"/>
        <result property="guNm"       column="gu_nm"/>
        <result property="startYy"    column="start_yy"/>
        <result property="startMm"    column="start_mm"/>
        <result property="endYy"      column="end_yy"/>
        <result property="endMm"      column="end_mm"/>
        <result property="ntnlBgt"    column="ntnl_bgt"/>
        <result property="lclBgt"     column="lcl_bgt"/>
        <result property="delYn"      column="del_yn"/>
    </resultMap>

    <!-- ================================
         SELECT LIST  (예산 목록)
         ================================ -->
    <select id="selectBgtMngList" parameterType="com.heang.springmybatistest.vo.BgtMngInVO"
            resultMap="bgtMngOutResult">
        SELECT
            ROW_NUMBER() OVER (ORDER BY id) AS rn,
            id,
            CASE
                WHEN sigungu_nm IS NOT NULL AND sigungu_nm != '' THEN sido_nm || ' ' || sigungu_nm
                ELSE sido_nm
            END AS jijache_nm,
            start_yy || '-' || start_mm AS start_mm_full,
            end_yy   || '-' || end_mm   AS end_mm_full,
            ntnl_bgt,
            lcl_bgt,
            ntnl_bgt + lcl_bgt AS bgt_sum
        FROM budget_mng
        <where>
            AND del_yn = 'N'
            <if test="sigunguCd != null and sigunguCd != ''">
                AND sigungu_cd = #{sigunguCd}
            </if>
            <if test="guCd != null and guCd != ''">
                AND gu_cd = #{guCd}
            </if>
            <if test="wholPrdYn == null">
                <if test="srchStrtMm != null and srchStrtMm != ''">
                    AND (start_yy || '-' || start_mm) &gt;= #{srchStrtMm}
                </if>
                <if test="srchEndMm != null and srchEndMm != ''">
                    AND (end_yy || '-' || end_mm) &lt;= #{srchEndMm}
                </if>
            </if>
        </where>
        ORDER BY id
    </select>

    <!-- ================================
         SELECT DETAIL  (상세조회 — 팝업 수정용)
         ================================ -->
    <select id="selectBgtMngDetail" parameterType="com.heang.springmybatistest.vo.BgtMngInVO"
            resultMap="bgtMngDetailResult">
        SELECT id, sido_cd, sido_nm, sigungu_cd, sigungu_nm,
               gu_cd, gu_nm, start_yy, start_mm, end_yy, end_mm,
               ntnl_bgt, lcl_bgt, del_yn
        FROM budget_mng
        WHERE id = #{id}
          AND del_yn = 'N'
    </select>

    <!-- ================================
         INSERT  (예산 등록)
         ================================ -->
    <insert id="insertBgtMng" parameterType="com.heang.springmybatistest.vo.BgtMngInVO">
        INSERT INTO budget_mng (
            sido_cd, sido_nm, sigungu_cd, sigungu_nm, gu_cd, gu_nm,
            start_yy, start_mm, end_yy, end_mm,
            ntnl_bgt, lcl_bgt
        ) VALUES (
            #{sidoCd}, #{sidoNm}, #{sigunguCd}, #{sigunguNm}, #{guCd}, #{guNm},
            #{startYy}, #{startMm}, #{endYy}, #{endMm},
            #{ntnlBgt}, #{lclBgt}
        )
    </insert>

    <!-- ================================
         UPDATE  (예산 수정)
         ================================ -->
    <update id="updateBgtMng" parameterType="com.heang.springmybatistest.vo.BgtMngInVO">
        UPDATE budget_mng
        <set>
            <if test="sigunguCd != null and sigunguCd != ''">sigungu_cd = #{sigunguCd},</if>
            <if test="sigunguNm != null and sigunguNm != ''">sigungu_nm = #{sigunguNm},</if>
            <if test="guCd != null">gu_cd = #{guCd},</if>
            <if test="guNm != null">gu_nm = #{guNm},</if>
            <if test="startYy != null and startYy != ''">start_yy = #{startYy},</if>
            <if test="startMm != null and startMm != ''">start_mm = #{startMm},</if>
            <if test="endYy != null and endYy != ''">end_yy = #{endYy},</if>
            <if test="endMm != null and endMm != ''">end_mm = #{endMm},</if>
            <if test="ntnlBgt != null">ntnl_bgt = #{ntnlBgt},</if>
            <if test="lclBgt != null">lcl_bgt = #{lclBgt},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{id}
          AND del_yn = 'N'
    </update>

    <!-- ================================
         DELETE  (soft delete — 예산 삭제)
         ================================ -->
    <update id="deleteBgtMng" parameterType="com.heang.springmybatistest.vo.BgtMngInVO">
        UPDATE budget_mng
        SET del_yn     = 'Y',
            updated_at = NOW()
        WHERE id = #{id}
    </update>

</mapper>
